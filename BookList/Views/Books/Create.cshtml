@model BookList.Models.Book

<h2>Add Book</h2>

<form asp-action="Create">

    <div class="mb-3">

        <label>Title</label>

        <input asp-for="Title" class="form-control" />

    </div>

    <div class="mb-3">

        <label>Author</label>

        <input asp-for="Author" class="form-control" />

    </div>

    <div class="mb-3">

        <label>Price</label>

        <input asp-for="Price" class="form-control" />

    </div>

    <button class="btn btn-success">
        Save
    </button>

</form>